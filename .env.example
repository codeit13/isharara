# Database (required)
DATABASE_URL=postgres://user:password@localhost:5432/your_database

# Session secret (optional; defaults to a dev secret if unset)
# SESSION_SECRET=your-secret-at-least-32-chars

# Google OAuth (optional; omit to hide "Login with Google")
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Base URL for OAuth callbacks (optional; defaults to http://localhost:3001)
# BASE_URL=http://localhost:3001

# Razorpay (optional; omit to disable Pay Online at checkout)
# From https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID=rzp_test_SLyEqdGAemtf7i
# RAZORPAY_KEY_SECRET=eiT4w36F8A4ul43fphXd0lCl

# Replit Object Storage (optional; for product image uploads on Replit deployments)
# Set to your bucket ID from .replit [objectStorage] defaultBucketID
# REPLIT_OBJECT_STORAGE_BUCKET=replit-objstore-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Cloudinary (fallback when Replit storage unavailable; e.g. in production deployments)
# Free at https://cloudinary.com — Dashboard shows cloud_name, api_key, api_secret
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# UPI direct payment (required for "Pay via UPI App" option)
# Your business UPI VPA e.g. ishqara@upi or 9876543210@paytm
VITE_UPI_ID=your-upi-id@bank
VITE_UPI_BUSINESS_NAME=ISHQARA
